            <div class="text-xs mt-1" style="color:var(--muted);">
              ${c.tipo==="percentual" ? `${c.valor}% de desconto` : `R$ ${Number(c.valor).toFixed(2)} de desconto`}
              ${c.limiteUsos ? ` · ${c.usos||0}/${c.limiteUsos} usos` : ` · ${c.usos||0} uso(s)`}
              ${c.validade ? ` · válido até ${new Date(c.validade).toLocaleDateString("pt-BR")}` : ""}
            </div>
          </div>
