async function getPontosPorNick() {
  const players = await fsList("cadastros");
  const pontosArr = await Promise.all(players.map((p) => fsGet("pontos", sanitize(p.nickJogo))));
  const pontos = {};
  players.forEach((p, i) => { pontos[p.nickJogo] = pontosArr[i]?.valor || 0; });
  return { players, pontos };
}

// A pontuação de cada tribo é a soma dos pontos de todos os jogadores cadastrados
// naquela tribo — assim quem sobe de pontuação individual também empurra a tribo
// para cima no ranking.
async function getRankingTribos() {
  const { players, pontos } = await getPontosPorNick();
  const grupos = {};
  players.forEach((p) => {
    const nomeTribo = (p.tribo || "").trim();
    if (!nomeTribo) return;
    if (!grupos[nomeTribo]) grupos[nomeTribo] = { nome: nomeTribo, pontos: 0, membros: 0 };
    grupos[nomeTribo].pontos += pontos[p.nickJogo] || 0;
    grupos[nomeTribo].membros += 1;
  });
  return Object.values(grupos).sort((a, b) => b.pontos - a.pontos);
}

async function getRankingJogadores() {
  const { players, pontos } = await getPontosPorNick();
  return players
    .map((p) => ({ nick: p.nickJogo, tribo: p.tribo || "", pontos: pontos[p.nickJogo] || 0 }))
    .sort((a, b) => b.pontos - a.pontos);
}

