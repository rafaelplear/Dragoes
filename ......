async function tplPontuacao() {
  const players = await fsList("cadastros");
  const pontosArr = await Promise.all(players.map((p) => fsGet("pontos", sanitize(p.nickJogo))));
  const pontos = {};
  players.forEach((p, i) => { pontos[p.nickJogo] = pontosArr[i]?.valor || 0; });
  window.__pontosCache = pontos;

  // Agrupa os jogadores pela tribo deles, pra facilitar achar quem pontuar.
  const grupos = {};
  players.forEach((p) => {
    const nomeTribo = (p.tribo || "").trim() || "Sem tribo";
    if (!grupos[nomeTribo]) grupos[nomeTribo] = [];
    grupos[nomeTribo].push(p);
  });
  const nomesTribos = Object.keys(grupos).sort((a, b) => a.localeCompare(b, "pt-BR"));

  const cardJogador = (pl) => `
    <div class="card p-3 flex items-center justify-between flex-wrap gap-2">
      <div>
        <div class="text-sm font-semibold">${pl.nickJogo}</div>
        <div class="text-xs" style="color:var(--muted);">${pl.cargo}</div>
      </div>
      <div class="flex items-center gap-2">
        <button data-action="pt-add" data-nick="${pl.nickJogo}" data-delta="-10" class="icon-btn p-1.5 rounded-md" style="background:var(--panel2);" title="-10 pontos"><i data-lucide="minus" style="width:13px;height:13px; color:var(--ember);"></i></button>
        <span class="font-display text-sm w-10 text-center" style="color:var(--gold);">${pontos[pl.nickJogo]}</span>
        <button data-action="pt-add" data-nick="${pl.nickJogo}" data-delta="10" class="icon-btn p-1.5 rounded-md" style="background:var(--panel2);" title="+10 pontos"><i data-lucide="plus" style="width:13px;height:13px; color:#4CAF6D;"></i></button>
        <input id="ajuste-${sanitize(pl.nickJogo)}" type="number" placeholder="+/-" class="text-xs px-2 py-1.5 rounded-md" style="width:60px; background:var(--panel2); color:var(--text); border:1px solid var(--border);" />
        <button data-action="pt-aplicar" data-nick="${pl.nickJogo}" class="btn-ghost">Aplicar</button>
      </div>
    </div>`;

  return `
  <div class="text-xs mb-3" style="color:var(--muted);">Escolha a tribo, depois o jogador dentro dela, e ajuste os pontos direto no jogador. A pontuação da tribo no ranking é sempre a soma dos jogadores dela.</div>
  <button data-action="admin-refresh" class="text-xs mb-3" style="color:var(--muted);">↻ Atualizar</button>
  ${players.length===0 ? `<div class="text-sm" style="color:var(--muted);">Nenhum jogador cadastrado.</div>` : ""}
  <div class="space-y-5">
    ${nomesTribos.map((nomeTribo) => `
      <div>
        <div class="flex items-center gap-2 mb-2">
          <i data-lucide="flag" style="width:14px;height:14px; color:var(--gold-dim);"></i>
          <div class="font-display text-sm" style="color:var(--gold);">${nomeTribo}</div>
          <div class="text-xs" style="color:var(--muted);">· ${grupos[nomeTribo].length} jogador(es)</div>
        </div>
        <div class="space-y-2">
          ${grupos[nomeTribo].map(cardJogador).join("")}
        </div>
      </div>`).join("")}
  </div>`;
}

