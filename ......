<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;900&family=Manrope:wght@400;500;600;700;800&display=swap');
  :root{
    --bg:#0F0D0A; --bg-glow: radial-gradient(1200px 600px at 50% -10%, rgba(200,155,60,.08), transparent 60%);
    --panel:#1B1611; --panel2:#231C15; --panel3:#2A2118; --border:#3A2F22; --border-soft:#2A2219;
    --ember:#B23A2E; --ember-soft:#7A2A22; --ember-glow: rgba(178,58,46,.35);
    --gold:#C89B3C; --gold-dim:#8E6E2E; --teal:#3E6B54;
    --text:#EDE6D6; --muted:#9C8F7A; --muted-dim:#6E6353;
  }
  *{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    background-color:var(--bg); background-image:var(--bg-glow); color:var(--text);
    font-family:'Manrope',sans-serif; min-height:100vh;
  }
  .font-display{ font-family:'Cinzel',serif; letter-spacing:.04em; }
  .text-muted{ color:var(--muted); }
  .rune-divider{ display:flex; align-items:center; gap:.6rem; color:var(--gold-dim); }
  .rune-divider::before, .rune-divider::after{ content:""; flex:1; height:1px; background:linear-gradient(90deg, transparent, var(--border), transparent); }
  .selo{
    display:flex; align-items:center; justify-content:center; border-radius:9999px; flex-shrink:0; position:relative;
    background:radial-gradient(circle at 35% 30%, var(--ember-soft), var(--panel2) 70%);
    border:2px solid var(--gold); box-shadow:0 0 16px var(--ember-glow), inset 0 0 10px rgba(0,0,0,.45);
  }
  .selo::after{
    content:""; position:absolute; inset:-6px; border-radius:9999px; border:1px solid rgba(200,155,60,.25); pointer-events:none;
  }
  .selo.dim{ border-color:var(--border); box-shadow:none; }
  .selo.dim::after{ display:none; }
  .dot{ width:8px; height:8px; border-radius:9999px; display:inline-block; margin-right:8px; background:#5A5148; }
  .dot.on{ background:#4CAF6D; box-shadow:0 0 6px #4CAF6D; }
  .input{
    background:var(--panel2); color:var(--text); border:1px solid var(--border); border-radius:.6rem;
    padding:.6rem .85rem; font-size:.875rem; width:100%; transition:border-color .15s ease, box-shadow .15s ease;
  }
  .input:focus{ outline:none; border-color:var(--gold-dim); box-shadow:0 0 0 3px rgba(200,155,60,.12); }
  .btn-ember{
    background:linear-gradient(180deg, #C4453A, var(--ember)); color:#fff; font-weight:700; border-radius:.6rem;
    padding:.65rem 1.1rem; letter-spacing:.01em; border:1px solid rgba(0,0,0,.15); box-shadow:0 2px 0 rgba(0,0,0,.25), 0 4px 14px rgba(178,58,46,.25);
    transition:transform .12s ease, box-shadow .12s ease; cursor:pointer;
  }
  .btn-ember:hover{ transform:translateY(-1px); box-shadow:0 3px 0 rgba(0,0,0,.25), 0 8px 18px rgba(178,58,46,.35); }
  .btn-ember:active{ transform:translateY(0); }
  .btn-ghost{
    background:var(--panel2); color:var(--text); border:1px solid var(--border); border-radius:.6rem;
    padding:.55rem .95rem; font-size:.8rem; font-weight:600; cursor:pointer; transition:border-color .15s ease, color .15s ease;
  }
  .btn-ghost:hover{ border-color:var(--gold-dim); color:var(--gold); }
  .card{
    background:linear-gradient(180deg, var(--panel), var(--panel2)); border:1px solid var(--border-soft);
    border-radius:.9rem; box-shadow:0 1px 0 rgba(255,255,255,.02) inset, 0 8px 20px rgba(0,0,0,.18);
    transition:border-color .18s ease, transform .18s ease;
  }
  .card-link:hover{ border-color:var(--gold-dim); transform:translateY(-2px); }
  .pill{ border-radius:9999px; font-weight:600; }
  .stat-num{ font-family:'Cinzel',serif; font-weight:700; }
  ::-webkit-scrollbar{ height:6px; width:6px; }
  ::-webkit-scrollbar-thumb{ background:var(--border); border-radius:4px; }
  @media (prefers-reduced-motion: reduce){ *{ transition:none !important; } }

  /* ---- Nav mais suave ---- */
  #nav{ box-shadow:0 1px 0 rgba(200,155,60,.08), 0 10px 24px rgba(0,0,0,.25); }
  .nav-btn{
    position:relative; border-radius:9999px; transition:background-color .2s ease, color .2s ease, transform .12s ease;
  }
  .nav-btn:hover{ background:rgba(200,155,60,.08); color:var(--gold) !important; }
  .nav-btn:active{ transform:scale(.96); }
  .nav-btn.is-active{ background:linear-gradient(180deg, rgba(200,155,60,.16), rgba(200,155,60,.06)); box-shadow:inset 0 0 0 1px rgba(200,155,60,.35); }
  .nav-adm-btn{ border-radius:9999px; transition:background-color .2s ease, transform .12s ease; }
  .nav-adm-btn:hover{ background:rgba(200,155,60,.1) !important; transform:translateY(-1px); }

  /* ---- Tabs (abas) mais suaves, usadas no admin e no ranking ---- */
  .tab-btn{ transition:background-color .2s ease, color .2s ease, border-color .2s ease, transform .1s ease; }
  .tab-btn:hover{ transform:translateY(-1px); }
  .tab-btn:active{ transform:translateY(0); }

  /* ---- Tooltips simples via title nativo, com leve destaque em botões de ícone ---- */
  .icon-btn{ transition:background-color .15s ease, transform .12s ease, color .15s ease; border-radius:.5rem; }
  .icon-btn:hover{ background:rgba(255,255,255,.05); transform:translateY(-1px); }
</style>
