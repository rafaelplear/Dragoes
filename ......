async function render() {
  renderNav();
  const app = document.getElementById("app");
  if (state.view === "home") await renderHome();
  else if (state.view === "loja") await renderLoja();
  else if (state.view === "eventos") await renderEventos();
  else if (state.view === "cadastro") await renderCadastro();
  else if (state.view === "ranking") await renderRanking();
  else if (state.view === "admin") state.isAdmin ? await renderAdmin() : renderAdminLogin();
  icons();
}

/* ============================================================
   AÇÕES (delegação de eventos)
   ============================================================ */
document.addEventListener("click", async (e) => {
  const el = e.target.closest("[data-action]");
  if (!el) return;
  const action = el.dataset.action;

  if (action === "nav") { state.view = el.dataset.view; state.cartOpen = false; return render(); }
  if (action === "cat") { state.categoria = el.dataset.cat; return renderLoja(); }
  if (action === "ranking-tab") { state.rankingTab = el.dataset.tab; return renderRanking(); }

  if (action === "add" || action === "inc") {
    const itens = window.__itensCache || await getItens();
    const item = itens.find((i) => i.id === el.dataset.id);
    if (!item) return;
    state.cart[item.id] = { ...item, qtd: (state.cart[item.id]?.qtd || 0) + 1 };
    return renderLoja();
  }
  if (action === "dec") {
    const cur = state.cart[el.dataset.id];
    if (cur) { if (cur.qtd <= 1) delete state.cart[el.dataset.id]; else cur.qtd -= 1; }
    return renderLoja();
  }
  if (action === "rm") { delete state.cart[el.dataset.id]; return renderLoja(); }
  if (action === "opencart") { state.cartOpen = true; return renderLoja(); }
  if (action === "closecart") { state.cartOpen = false; return renderLoja(); }

  if (action === "cupom-aplicar") {
    const codigoDigitado = document.getElementById("cupomInput").value.trim();
    if (!codigoDigitado) return toast("Digite um código de cupom.");
    const resultado = await validarCupom(codigoDigitado);
    if (!resultado.ok) return toast(resultado.erro);
    state.cupomAplicado = { id: resultado.cupom.id, codigo: resultado.cupom.codigo, tipo: resultado.cupom.tipo, valor: resultado.cupom.valor };
    toast(`Cupom ${resultado.cupom.codigo} aplicado!`);
    return renderLoja();
  }
  if (action === "cupom-remover") { state.cupomAplicado = null; return renderLoja(); }

  if (action === "finalizar") {
    const nickVal = (document.getElementById("nickInputCart")?.value || document.getElementById("nickInput")?.value || "").trim();
    if (!nickVal) return toast("Digite seu nick antes de finalizar o pedido.");
    const cartItems = Object.values(state.cart);
    if (cartItems.length === 0) return toast("Seu carrinho está vazio.");
    state.nick = nickVal;
    const subtotal = cartItems.reduce((s, i) => s + i.preco * i.qtd, 0);
    const desconto = calcularDesconto(subtotal, state.cupomAplicado);
    const total = subtotal - desconto;
    const linhas = cartItems.map((i) => `• ${i.qtd}x ${i.nome} — R$${(i.preco*i.qtd).toFixed(2)}`).join("\n");
    const linhaDesconto = desconto > 0 ? `\nCupom ${state.cupomAplicado.codigo}: −R$${desconto.toFixed(2)}` : "";
    const texto = `*Novo pedido - Reino dos Dragões*\nServidor: ${state.servidor}\nJogador: ${nickVal}\n\n${linhas}${linhaDesconto}\n\n*Total: R$${total.toFixed(2)}*`;
    const urlPedido = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(texto)}`;
    // IMPORTANTE: abrir o WhatsApp é a PRIMEIRA coisa que fazemos, ainda de forma síncrona
    // dentro do clique do usuário — sem esperar nada do Firestore antes. Isso evita que o
    // navegador (principalmente no celular) bloqueie o redirecionamento ou perca o número
    // certo por causa da demora de salvar o pedido.
    window.open(urlPedido, "_blank");
    const cupomUsado = state.cupomAplicado;
    const pedido = {
      nick: nickVal, servidor: state.servidor,
      itens: cartItems.map((i) => ({ nome: i.nome, qtd: i.qtd, preco: i.preco })),
      subtotal, desconto, cupom: cupomUsado?.codigo || null,
      total, status: "pendente", timestamp: Date.now(),
    };
    state.cart = {}; state.cartOpen = false; state.cupomAplicado = null;
    toast("Pedido enviado! Continue a conversa no WhatsApp que abriu.");
    renderLoja();
    // Salva o pedido e atualiza o uso do cupom em segundo plano, sem travar o redirecionamento.
    fsAdd("pedidos", pedido);
    if (cupomUsado) {
      fsGet("cupons", cupomUsado.id).then((cupomAtual) => {
        if (cupomAtual) fsSet("cupons", cupomUsado.id, { ...cupomAtual, usos: (cupomAtual.usos || 0) + 1 });
      });
    }
    return;
  }

  if (action === "palpite-enviar") {
    const nickVal = document.getElementById("nickInputEv")?.value.trim();
    const n = document.getElementById("golsNoruega").value;
    const b = document.getElementById("golsBrasil").value;
    if (!nickVal) return toast("Digite seu nick antes de palpitar.");
    if (n === "" || b === "") return toast("Preencha os dois placares.");
    state.nick = nickVal;
    await fsSet("palpites", sanitize(nickVal), { nick: nickVal, noruega: Number(n), brasil: Number(b), timestamp: Date.now() });
    toast("Palpite salvo!");
    return renderEventos();
  }

  if (action === "cadastro-finalizar") {
    const nome = document.getElementById("cNome").value.trim();
    const telefone = document.getElementById("cTelefone").value.trim();
    const nickVal = document.getElementById("cNick").value.trim();
    const tribo = document.getElementById("cTribo").value.trim();
    const cargo = document.getElementById("cCargo").value;
    const servidor = document.getElementById("cServidor").value;
    if (!nome || !telefone || !nickVal) return toast("Preencha nome, telefone e nick no jogo.");
    // Abre a aba já aqui, no clique direto do usuário, para o navegador não bloquear o pop-up
    // (se abrirmos só depois do await, alguns navegadores tratam como bloqueio de pop-up).
    const novaAba = window.open("", "_blank");
    state.nick = nickVal;
    await fsSet("cadastros", sanitize(nickVal), { nome, telefone, nickJogo: nickVal, tribo, cargo, servidor, lastSeen: Date.now() });
    const texto = `*Novo cadastro - Reino dos Dragões*\nNome: ${nome}\nNick no jogo: ${nickVal}\nTelefone: ${telefone}\nTribo: ${tribo || "-"}\nCargo: ${cargo}\nServidor: ${servidor}\n\nOlá! Acabei de me cadastrar no site e gostaria de receber meu kit de boas-vindas e o link do grupo. ⚔️`;
    const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(texto)}`;
    if (novaAba) novaAba.location.href = url; else window.open(url, "_blank");
    toast("Cadastro salvo! Continue a conversa no WhatsApp.");
    return renderCadastro();
  }
  if (action === "marcar-online") {
    if (!state.nick) return;
    const atual = await fsGet("cadastros", sanitize(state.nick));
    await fsSet("cadastros", sanitize(state.nick), { ...(atual||{}), lastSeen: Date.now() });
    toast("Você está marcado como online!");
    return renderCadastro();
  }

  if (action === "admin-login") {
    const pass = document.getElementById("adminPass").value;
    const btn = el; const original = btn.textContent;
    btn.textContent = "Verificando..."; btn.disabled = true;
    const ok = await checkAdminPassword(pass);
    btn.disabled = false; btn.textContent = original;
    if (ok) { state.isAdmin = true; return render(); }
    document.getElementById("adminErro").classList.remove("hidden");
  }
  if (action === "admin-logout") { state.isAdmin = false; state.view = "home"; return render(); }
  if (action === "admin-tab") { state.adminTab = el.dataset.tab; return renderAdmin(); }
  if (action === "admin-loja-cat") { state.adminLojaCat = el.dataset.cat; return renderAdmin(); }
  if (action === "admin-refresh") { return renderAdmin(); }

  if (action === "cadastro-criar-manual") {
    const nome = document.getElementById("mcNome").value.trim();
    const telefone = document.getElementById("mcTelefone").value.trim();
    const nickVal = document.getElementById("mcNick").value.trim();
    const tribo = document.getElementById("mcTribo").value.trim();
    const cargo = document.getElementById("mcCargo").value;
    const servidor = document.getElementById("mcServidor").value;
    if (!nome || !nickVal) return toast("Preencha ao menos nome e nick.");
    await fsSet("cadastros", sanitize(nickVal), { nome, telefone, nickJogo: nickVal, tribo, cargo, servidor, lastSeen: 0 });
    toast("Cadastro adicionado.");
    return renderAdmin();
  }
  if (action === "cadastro-excluir") {
    await fsDelete("cadastros", el.dataset.id);
    toast("Cadastro removido.");
    return renderAdmin();
  }

  if (action === "pedido-toggle") {
    const novoStatus = el.dataset.status === "entregue" ? "pendente" : "entregue";
    const doc = (await fsList("pedidos")).find((p) => p.id === el.dataset.id);
    if (doc) { const { id, ...data } = doc; await fsSet("pedidos", id, { ...data, status: novoStatus }); }
    return renderAdmin();
  }
  if (action === "pedido-excluir") { await fsDelete("pedidos", el.dataset.id); toast("Pedido removido."); return renderAdmin(); }

  if (action === "aviso-add") {
    const servidor = document.getElementById("avisoServidor").value;
    const texto = document.getElementById("avisoNovo").value.trim();
    if (!texto) return;
    state.servidor = servidor;
    const atual = (await fsGet("avisos", sanitize(servidor)))?.lista || [];
    await fsSet("avisos", sanitize(servidor), { lista: [...atual, { texto, data: Date.now() }] });
    toast("Aviso publicado.");
    return renderAdmin();
  }
  if (action === "aviso-rm") {
    const servidor = document.getElementById("avisoServidor").value;
    const atual = (await fsGet("avisos", sanitize(servidor)))?.lista || [];
    atual.splice(Number(el.dataset.idx), 1);
    await fsSet("avisos", sanitize(servidor), { lista: atual });
    return renderAdmin();
  }

  if (action === "pt-add") {
    const nick = el.dataset.nick;
    const atual = window.__pontosCache?.[nick] || 0;
    const novo = atual + Number(el.dataset.delta);
    const ok = await fsSet("pontos", sanitize(nick), { valor: novo });
    if (!ok) return toast("Não consegui salvar a pontuação. Veja o console (F12) ou as regras do Firestore.");
    return renderAdmin();
  }
  if (action === "pt-aplicar") {
    const nick = el.dataset.nick;
    const val = Number(document.getElementById(`ajuste-${sanitize(nick)}`).value);
    if (!val) return toast("Digite um número diferente de zero para aplicar.");
    const atual = window.__pontosCache?.[nick] || 0;
    const ok = await fsSet("pontos", sanitize(nick), { valor: atual + val });
    if (!ok) return toast("Não consegui salvar a pontuação. Veja o console (F12) ou as regras do Firestore.");
    toast("Pontuação atualizada.");
    return renderAdmin();
  }

  if (action === "tribo-criar") {
    const nome = document.getElementById("triboNovoNome").value.trim();
    if (!nome) return;
    const existente = await fsGet("tribos", sanitize(nome));
    if (existente) { toast("Já existe uma tribo com esse nome."); return renderAdmin(); }
    await fsSet("tribos", sanitize(nome), { nome, pontos: 0, membros: [] });
    toast("Tribo criada!");
    return renderAdmin();
  }
  if (action === "tribo-excluir") {
    await fsDelete("tribos", sanitize(el.dataset.tribo));
    toast("Tribo removida.");
    return renderAdmin();
  }
  if (action === "tribo-membro-add") {
    const nome = el.dataset.tribo;
    const tid = sanitize(nome);
    const nomeMembro = document.getElementById(`novoMembro-${tid}`).value.trim();
    if (!nomeMembro) return;
    const tribo = await fsGet("tribos", tid);
    if (!tribo) return;
    const membros = [...(tribo.membros||[]), { nome: nomeMembro, cargo: "Membro" }];
    await fsSet("tribos", tid, { ...tribo, membros });
    toast("Membro adicionado.");
    return renderAdmin();
  }
  if (action === "tribo-membro-rm") {
    const tid = sanitize(el.dataset.tribo);
    const tribo = await fsGet("tribos", tid);
    if (!tribo) return;
    const membros = (tribo.membros||[]).filter((_, i) => i !== Number(el.dataset.idx));
    await fsSet("tribos", tid, { ...tribo, membros });
    return renderAdmin();
  }
  if (action === "tribo-membro-cargo") {
    const tid = sanitize(el.dataset.tribo);
    const tribo = await fsGet("tribos", tid);
    if (!tribo) return;
    const membros = [...(tribo.membros||[])];
    const idx = Number(el.dataset.idx);
    membros[idx] = { ...membros[idx], cargo: membros[idx].cargo === "Líder" ? "Membro" : "Líder" };
    await fsSet("tribos", tid, { ...tribo, membros });
    return renderAdmin();
  }

  if (action === "cat-criar") {
    const nome = document.getElementById("catNovaNome").value.trim();
    if (!nome) return toast("Digite o nome da categoria.");
    const id = sanitize(nome);
    const existente = await fsGet("categorias", id);
    if (existente) { toast("Já existe uma categoria com esse nome."); return renderAdmin(); }
    const categorias = await getCategorias();
    const maiorOrdem = categorias.reduce((m, c) => Math.max(m, c.ordem || 0), 0);
    await fsSet("categorias", id, { nome, ordem: maiorOrdem + 1 });
    toast("Categoria criada!");
    return renderAdmin();
  }
  if (action === "cat-renomear") {
    const id = el.dataset.id;
    const nomeAntigo = el.dataset.nome;
    const nomeNovo = document.getElementById(`catNome-${id}`).value.trim();
    if (!nomeNovo) return toast("O nome não pode ficar em branco.");
    if (nomeNovo === nomeAntigo) return;
    const cat = await fsGet("categorias", id);
    await fsSet("categorias", id, { ...cat, nome: nomeNovo });
    const itens = await fsList("itens");
    const afetados = itens.filter((i) => i.categoria === nomeAntigo);
    for (const it of afetados) {
      const { id: itemId, ...data } = it;
      await fsSet("itens", itemId, { ...data, categoria: nomeNovo });
    }
    if (state.categoria === nomeAntigo) state.categoria = nomeNovo;
    toast("Categoria renomeada.");
    return renderAdmin();
  }
  if (action === "cat-excluir") {
    const id = el.dataset.id;
    const nome = el.dataset.nome;
    const itens = await fsList("itens");
    const afetados = itens.filter((i) => i.categoria === nome);
    for (const it of afetados) await fsDelete("itens", it.id);
    await fsDelete("categorias", id);
    toast(afetados.length ? `Categoria e ${afetados.length} item(ns) removidos.` : "Categoria removida.");
    return renderAdmin();
  }
  if (action === "item-criar") {
    const cid = el.dataset.cid;
    const categoria = el.dataset.categoria;
    const nome = document.getElementById(`itNovoNome-${cid}`).value.trim();
    const preco = Number(document.getElementById(`itNovoPreco-${cid}`).value);
    const imagem = document.getElementById(`itNovoImg-${cid}`).value.trim();
    const descricao = document.getElementById(`itNovoDesc-${cid}`).value.trim();
    if (!nome || !preco || preco <= 0) return toast("Preencha nome e preço do item.");
    await fsAdd("itens", { nome, preco, categoria, imagem: imagem || null, descricao: descricao || null });
    toast("Item adicionado!");
    return renderAdmin();
  }
  if (action === "item-salvar") {
    const id = el.dataset.id;
    const nome = document.getElementById(`itNome-${id}`).value.trim();
    const preco = Number(document.getElementById(`itPreco-${id}`).value);
    const categoria = document.getElementById(`itCat-${id}`).value;
    const imagem = document.getElementById(`itImg-${id}`).value.trim();
    const descricao = document.getElementById(`itDesc-${id}`).value.trim();
    if (!nome || !preco || preco <= 0) return toast("Preencha nome e preço do item.");
    await fsSet("itens", id, { nome, preco, categoria, imagem: imagem || null, descricao: descricao || null });
    toast("Item atualizado.");
    return renderAdmin();
  }
  if (action === "item-excluir") {
    await fsDelete("itens", el.dataset.id);
    toast("Item removido.");
    return renderAdmin();
  }

  if (action === "cupom-criar") {
    const codigo = document.getElementById("cupNovoCodigo").value.trim().toUpperCase();
    const tipo = document.getElementById("cupNovoTipo").value;
    const valor = Number(document.getElementById("cupNovoValor").value);
    const limiteRaw = document.getElementById("cupNovoLimite").value;
    const validadeRaw = document.getElementById("cupNovoValidade").value;
    if (!codigo) return toast("Digite um código para o cupom.");
    if (!valor || valor <= 0) return toast("Digite um valor de desconto válido.");
    if (tipo === "percentual" && valor > 100) return toast("Desconto percentual não pode passar de 100%.");
    const id = sanitize(codigo);
    const existente = await fsGet("cupons", id);
    if (existente) { toast("Já existe um cupom com esse código."); return renderAdmin(); }
    await fsSet("cupons", id, {
      codigo, tipo, valor,
      limiteUsos: limiteRaw ? Number(limiteRaw) : null,
      validade: validadeRaw ? new Date(validadeRaw + "T23:59:59").getTime() : null,
      ativo: true, usos: 0, criadoEm: Date.now(),
    });
    toast("Cupom criado!");
    return renderAdmin();
  }
  if (action === "cupom-toggle") {
    const cupom = await fsGet("cupons", el.dataset.id);
    if (!cupom) return;
    await fsSet("cupons", el.dataset.id, { ...cupom, ativo: cupom.ativo === false ? true : false });
    return renderAdmin();
  }
  if (action === "cupom-excluir") {
    await fsDelete("cupons", el.dataset.id);
    toast("Cupom removido.");
    return renderAdmin();
  }

  if (action === "resultado-salvar") {
    const n = document.getElementById("resNoruega").value;
    const b = document.getElementById("resBrasil").value;
    if (n === "" || b === "") return;
    await fsSet("config", "resultado", { noruega: Number(n), brasil: Number(b) });
    toast("Resultado oficial definido.");
    return renderAdmin();
  }
  if (action === "palpites-limpar") {
    const list = await fsList("palpites");
    for (const p of list) await fsDelete("palpites", p.id);
    await fsDelete("config", "resultado");
    toast("Palpites e resultado limpos.");
    return renderAdmin();
  }
  if (action === "palpite-excluir") {
    await fsDelete("palpites", el.dataset.id);
    toast("Palpite removido.");
    return renderAdmin();
  }
  if (action === "evento-remover") {
    await fsSet("config", "evento", { ativo: false });
    toast("Evento removido da aba Eventos.");
    return renderAdmin();
  }
  if (action === "evento-reativar") {
    await fsSet("config", "evento", { ativo: true });
    toast("Evento reativado.");
    return renderAdmin();
  }
});

document.addEventListener("change", (e) => {
  if (e.target.id === "servidorSelect") { state.servidor = e.target.value; return renderLoja(); }
});

document.addEventListener("keydown", (e) => {
  if (e.key === "Enter" && e.target.id === "adminPass") {
    document.querySelector('[data-action="admin-login"]')?.click();
  }
});

seedCatalogoSeNecessario().then(render);
</script>
</body>
</html>
