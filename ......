   ============================================================ */
const firebaseConfig = {
  apiKey: "AIzaSyAWLtl84Umajh8UAOnq6sNW46POZ_TCSvM",
  authDomain: "dragoes-1c33b.firebaseapp.com",
  projectId: "dragoes-1c33b",
  storageBucket: "dragoes-1c33b.firebasestorage.app",
  messagingSenderId: "4417567938",
  appId: "1:4417567938:web:2c077e2965b5bafecbcf5b",
  measurementId: "G-1FRDYCZ02H"
};
// A senha do ADM NÃO fica mais aqui no código — ela é lida direto do Firestore
// (coleção "config", documento "admin", campo "senha"). Veja as instruções que
// te mandei em separado para cadastrar essa senha no console do Firebase.
const WHATSAPP_NUMBER = "5516997161570"; // Número do ADM (DDI+DDD+número)
const GRUPO_WHATSAPP = "https://wa.me/5516997161570"; // Grupo oficial (para onde vai quem finaliza uma compra)
const SERVIDORES = ["Reino dos Dragões"];

// Este catálogo abaixo é usado só UMA VEZ, para popular o Firestore na primeira
// vez que o site rodar. Depois disso, categorias e itens são gerenciados pelo
// próprio Painel ADM (aba "Loja") e ficam salvos no Firestore.
const SEED_CATALOGO = [
  { categoria: "Destino Especial", itens: [
    { id: "de1", nome: "Teleporte para base", preco: 15 },
    { id: "de2", nome: "Teleporte para caverna de elementos", preco: 25 },
  ]},
  { categoria: "Criação Especial", itens: [
    { id: "ce1", nome: "Dino customizado (cor + stats)", preco: 40 },
    { id: "ce2", nome: "Skin exclusiva de estrutura", preco: 20 },
  ]},
  { categoria: "Base Pronta", itens: [
    { id: "bp1", nome: "Base pequena (metal)", preco: 60 },
    { id: "bp2", nome: "Base grande (tek)", preco: 150 },
  ]},
  { categoria: "Recursos", itens: [
    { id: "rc1", nome: "1000x Metal", preco: 10 },
    { id: "rc2", nome: "500x Cristal", preco: 12 },
    { id: "rc3", nome: "Element x50", preco: 35 },
  ]},
  { categoria: "Kits", itens: [
    { id: "kt1", nome: "Kit Iniciante", preco: 20 },
    { id: "kt2", nome: "Kit Tribo Completo", preco: 90 },
  ]},
  { categoria: "Ambos (Combo)", itens: [
    { id: "am1", nome: "Combo Base + Recursos", preco: 180 },
  ]},
];

firebase.initializeApp(firebaseConfig);
const db = firebase.firestore();

/* ============================================================
   HELPERS FIRESTORE
   ============================================================ */
const sanitize = (s) => (s || "").trim().toLowerCase()
  .normalize("NFD").replace(/[\u0300-\u036f]/g, "")
  .replace(/[^a-z0-9]+/g, "_").replace(/^_+|_+$/g, "") || "sem_nome";

async function fsGet(col, id) {
  try { const d = await db.collection(col).doc(id).get(); return d.exists ? d.data() : null; }
  catch (e) { console.error(e); return null; }
}
async function fsSet(col, id, data) {
  try { await db.collection(col).doc(id).set(data); return true; }
  catch (e) { console.error(e); return false; }
}
async function fsDelete(col, id) {
  try { await db.collection(col).doc(id).delete(); } catch (e) {}
}
async function fsAdd(col, data) {
  try { const ref = await db.collection(col).add(data); return ref.id; }
  catch (e) { console.error(e); return null; }
}
async function fsList(col) {
  try { const snap = await db.collection(col).get(); return snap.docs.map((d) => ({ id: d.id, ...d.data() })); }
  catch (e) { console.error(e); return []; }
}
async function checkAdminPassword(pass) {
  const doc = await fsGet("config", "admin");
  if (!doc || !doc.senha) return false;
  return String(doc.senha) === String(pass);
}

/* ============================================================
   CATÁLOGO DA LOJA (categorias + itens vivem no Firestore)
   ============================================================ */
async function getCategorias() {
  const cats = await fsList("categorias");
  return cats.sort((a, b) => (a.ordem || 0) - (b.ordem || 0));
}
async function getItens() {
  return fsList("itens");
}
async function seedCatalogoSeNecessario() {
  const categorias = await fsList("categorias");
  if (categorias.length > 0) return; // já existe catálogo salvo, não sobrescreve
  let ordem = 0;
  for (const cat of SEED_CATALOGO) {
    await fsSet("categorias", sanitize(cat.categoria), { nome: cat.categoria, ordem: ordem++ });
    for (const item of cat.itens) {
      await fsSet("itens", item.id, { nome: item.nome, preco: item.preco, categoria: cat.categoria });
    }
  }
}

/* ============================================================
   CUPONS DE DESCONTO
   ============================================================ */
function calcularDesconto(subtotal, cupom) {
  if (!cupom || subtotal <= 0) return 0;
  const bruto = cupom.tipo === "percentual" ? subtotal * (Number(cupom.valor) / 100) : Number(cupom.valor);
  return Math.min(Math.max(bruto, 0), subtotal);
}
function formatoDesconto(cupom) {
  return cupom.tipo === "percentual" ? `${cupom.valor}%` : `R$ ${Number(cupom.valor).toFixed(2)}`;
}
async function validarCupom(codigoDigitado) {
  const id = sanitize(codigoDigitado);
  const cupom = await fsGet("cupons", id);
  if (!cupom) return { ok: false, erro: "Cupom não encontrado." };
  if (cupom.ativo === false) return { ok: false, erro: "Esse cupom não está mais ativo." };
  if (cupom.validade && Date.now() > cupom.validade) return { ok: false, erro: "Esse cupom expirou." };
  if (cupom.limiteUsos && (cupom.usos || 0) >= cupom.limiteUsos) return { ok: false, erro: "Esse cupom atingiu o limite de usos." };
  return { ok: true, cupom: { id, ...cupom } };
}

/* ============================================================
   STATE
   ============================================================ */
const state = {
  view: "home",
  nick: "",
  isAdmin: false,
  cart: {},          // id -> {...item, qtd}
  cupomAplicado: null, // { id, codigo, tipo, valor }
  servidor: SERVIDORES[0],
  categoria: null,
  cartOpen: false,
  adminTab: "pedidos",
  rankingTab: "tribos",
};

function toast(msg) {
  const el = document.getElementById("toast");
  el.textContent = msg;
  el.classList.remove("hidden");
  clearTimeout(window.__toastTimer);
  window.__toastTimer = setTimeout(() => el.classList.add("hidden"), 3000);
}

function icons() { if (window.lucide) lucide.createIcons(); }

/* ============================================================
   NAV
   ============================================================ */
function renderNav() {
  const items = [["home","Início"],["loja","Loja"],["eventos","Eventos"],["ranking","Ranking"],["cadastro","Cadastro"]];
  document.getElementById("nav").innerHTML = `
    <button data-action="nav" data-view="home" class="nav-btn flex items-center gap-2.5 font-display text-sm sm:text-base px-1.5 py-1" title="Ir para o início">
      <div class="selo" style="width:32px;height:32px;font-size:15px;">⚔️</div>
      <span class="hidden sm:inline" style="color:var(--gold); letter-spacing:.08em;">REINO DOS DRAGÕES</span>
    </button>
    <div class="flex items-center gap-0.5 sm:gap-1 text-xs sm:text-sm">
      ${items.map(([key,label]) => `
        <button data-action="nav" data-view="${key}" class="nav-btn ${state.view===key?"is-active":""} px-2.5 sm:px-3.5 py-1.5 font-medium"
          style="color:${state.view===key?"var(--gold)":"var(--muted)"};" title="${label}">
          ${label}
        </button>`).join("")}
      <button data-action="nav" data-view="admin" class="nav-adm-btn ml-1 p-2" style="color:${state.isAdmin?"#4CAF6D":"var(--muted)"}; background:${state.view==="admin"?"rgba(200,155,60,.1)":"transparent"};" title="Área ADM">
        <i data-lucide="${state.isAdmin?"shield-check":"lock"}" style="width:16px;height:16px;"></i>
      </button>
    </div>
  `;
}

/* ============================================================
   HOME
   ============================================================ */
async function renderHome() {
  const [tribos, cadastros, pedidos] = await Promise.all([fsList("tribos"), fsList("cadastros"), fsList("pedidos")]);
  const onlineAgora = cadastros.filter((c) => c.lastSeen && Date.now() - c.lastSeen < 5*60*1000).length;
  const pendentes = pedidos.filter((p) => p.status !== "entregue").length;
  const stats = [
    ["users", cadastros.length, "Jogadores"],
    ["flag", tribos.length, "Tribos"],
    ["radio", onlineAgora, "Online agora"],
    ["package", pendentes, "Pedidos em aberto"],
  ];

  const sections = [
    ["loja","shopping-cart","Loja","Bases prontas, recursos, kits e criações sob medida para sua tribo.","var(--ember)"],
    ["eventos","swords","Eventos","Palpite no placar do reino e acompanhe as disputas ao vivo.","var(--gold)"],
    ["ranking","flag","Ranking","Veja quais tribos lideram a disputa por território e pontos.","var(--teal)"],
    ["cadastro","users","Cadastro","Registre seu nick, sua tribo e marque presença no servidor.","var(--gold)"],
  ];

  document.getElementById("app").innerHTML = `
  <div class="px-6 py-14 sm:py-20 text-center max-w-4xl mx-auto">
    <div class="selo mx-auto" style="width:84px;height:84px;"><span style="font-size:36px;">⚔️</span></div>
    <h1 class="font-display mt-6 text-4xl sm:text-6xl" style="color:var(--gold); text-shadow:0 0 30px rgba(200,155,60,.18);">REINO DOS DRAGÕES</h1>
    <p class="mt-3 max-w-lg mx-auto" style="color:var(--muted);">Portal oficial da comunidade. Abasteça sua tribo, dispute eventos, suba no ranking e marque presença no servidor.</p>

    <div class="rune-divider mt-10 mb-6 text-xs uppercase" style="letter-spacing:.15em;">Estado do reino</div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-12">
      ${stats.map(([icon, val, label]) => `
        <div class="card p-4">
          <i data-lucide="${icon}" style="width:16px;height:16px; color:var(--gold-dim);"></i>
          <div class="stat-num text-2xl mt-2" style="color:var(--text);">${val}</div>
          <div class="text-xs mt-0.5" style="color:var(--muted);">${label}</div>
        </div>`).join("")}
    </div>

    <div class="grid sm:grid-cols-2 gap-4 text-left">
      ${sections.map(([view, icon, title, desc, color]) => `
        <button data-action="nav" data-view="${view}" class="card card-link p-6">
          <div class="selo" style="width:44px;height:44px;"><i data-lucide="${icon}" style="color:${color}; width:19px; height:19px;"></i></div>
          <div class="font-display mt-4 text-lg" style="color:var(--text);">${title}</div>
          <div class="text-xs mt-1.5 leading-relaxed" style="color:var(--muted);">${desc}</div>
        </button>`).join("")}
    </div>
  </div>`;
  icons();
}

/* ============================================================
   LOJA
   ============================================================ */
async function renderLoja() {
  const [categorias, itens, avisos] = await Promise.all([
    getCategorias(), getItens(), fsGet("avisos", sanitize(state.servidor)).then((d) => d?.lista || []),
  ]);
  window.__itensCache = itens;

  if (!state.categoria || !categorias.find((c) => c.nome === state.categoria)) {
    state.categoria = categorias[0]?.nome || null;
  }

  const cartItems = Object.values(state.cart);
  const subtotal = cartItems.reduce((s, i) => s + i.preco * i.qtd, 0);
  const desconto = calcularDesconto(subtotal, state.cupomAplicado);
  const total = subtotal - desconto;
  const qtdTotal = cartItems.reduce((s, i) => s + i.qtd, 0);

  document.getElementById("app").innerHTML = `
  <div class="px-4 sm:px-8 py-8 max-w-6xl mx-auto">
    <div class="flex items-center gap-3 mb-4">
      <div class="selo" style="width:40px;height:40px;"><i data-lucide="shopping-cart" style="color:var(--ember); width:18px; height:18px;"></i></div>
      <h2 class="font-display text-2xl" style="color:var(--gold);">Loja</h2>
    </div>
    <div class="flex flex-wrap gap-3 mb-4">
      <select id="servidorSelect" class="input" style="width:auto;">
        ${SERVIDORES.map((s) => `<option value="${s}" ${s===state.servidor?"selected":""}>${s}</option>`).join("")}
      </select>
      <input id="nickInput" class="input flex-1" style="min-width:160px;" placeholder="Seu nick no jogo" value="${state.nick}" />
    </div>
    ${avisos.length ? `
    <div class="mb-5 p-3 rounded-lg text-sm flex items-start gap-2" style="background:#2A1F14; border:1px solid rgba(200,155,60,.35); color:var(--gold);">
      <i data-lucide="megaphone" style="width:16px;height:16px; margin-top:2px;"></i>
      <div>${avisos.map((a) => `<div>${a.texto}</div>`).join("")}</div>
    </div>` : ""}
    ${categorias.length === 0 ? `
      <div class="card p-6 text-sm text-center" style="color:var(--muted);">A loja ainda não tem categorias ou itens cadastrados. Peça para o ADM configurar em Painel ADM → Loja.</div>
    ` : `
    <div class="flex gap-2 mb-5 overflow-x-auto pb-1">
      ${categorias.map((c) => `
        <button data-action="cat" data-cat="${c.nome}" class="text-xs px-3 py-2 rounded-full whitespace-nowrap shrink-0"
          style="background:${state.categoria===c.nome?"var(--ember)":"var(--panel2)"}; color:${state.categoria===c.nome?"#fff":"var(--muted)"}; border:1px solid ${state.categoria===c.nome?"var(--ember)":"var(--border)"};">
          ${c.nome}
        </button>`).join("")}
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 pb-28">
      ${itens.filter((i) => i.categoria === state.categoria).length === 0 ? `<div class="text-sm col-span-full" style="color:var(--muted);">Nenhum item nessa categoria ainda.</div>` : ""}
      ${itens.filter((i) => i.categoria === state.categoria).map((item) => {
        const inCart = state.cart[item.id];
        return `
        <div class="card p-4 flex flex-col justify-between">
          <div>
            ${item.imagem ? `<img src="${item.imagem}" class="w-full rounded-lg object-cover mb-3" style="height:120px;" onerror="this.style.display='none'" />` : ""}
            <div class="font-semibold text-sm" style="color:var(--text);">${item.nome}</div>
            ${item.descricao ? `<div class="text-xs mt-1" style="color:var(--muted);">${item.descricao}</div>` : ""}
            <div class="text-xs mt-1" style="color:var(--gold);">R$ ${item.preco.toFixed(2)}</div>
          </div>
          <div class="flex items-center justify-between mt-3">
            ${inCart ? `
              <div class="flex items-center gap-2">
                <button data-action="dec" data-id="${item.id}" class="icon-btn p-1.5 rounded-md" style="background:var(--panel2);" title="Diminuir quantidade"><i data-lucide="minus" style="width:14px;height:14px;"></i></button>
                <span class="text-sm w-5 text-center">${inCart.qtd}</span>
                <button data-action="inc" data-id="${item.id}" class="icon-btn p-1.5 rounded-md" style="background:var(--panel2);" title="Aumentar quantidade"><i data-lucide="plus" style="width:14px;height:14px;"></i></button>
              </div>` : `
              <button data-action="add" data-id="${item.id}" class="text-xs px-3 py-1.5 rounded-md" style="background:var(--ember-soft); color:#fff;">Adicionar</button>`}
          </div>
        </div>`;
      }).join("")}
    </div>
    `}

    ${qtdTotal > 0 && !state.cartOpen ? `
      <button data-action="opencart" class="fixed bottom-5 right-5 px-4 py-3 rounded-full shadow-xl flex items-center gap-2 z-40 font-semibold" style="background:var(--gold); color:#1A1410;">
        <i data-lucide="shopping-cart" style="width:16px;height:16px;"></i> ${qtdTotal} · R$ ${total.toFixed(2)}
      </button>` : ""}

