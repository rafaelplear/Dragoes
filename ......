  <div class="space-y-2">
    ${cupons.map((c) => {
      const expirado = c.validade && Date.now() > c.validade;
      const esgotado = c.limiteUsos && (c.usos||0) >= c.limiteUsos;
      const ativo = c.ativo !== false && !expirado && !esgotado;
      let statusLabel = "Ativo", statusColor = "#4CAF6D", statusBg = "#1F3A28";
      if (c.ativo === false) { statusLabel = "Desativado"; statusColor = "var(--muted)"; statusBg = "var(--panel2)"; }
      else if (expirado) { statusLabel = "Expirado"; statusColor = "var(--ember)"; statusBg = "#3A1F1F"; }
      else if (esgotado) { statusLabel = "Esgotado"; statusColor = "var(--gold)"; statusBg = "#3A2A1F"; }
      return `
      <div class="card p-4">
        <div class="flex items-start justify-between gap-2 flex-wrap">
          <div>
            <div class="flex items-center gap-2">
              <span class="font-display text-base" style="color:var(--gold);">${c.codigo}</span>
              <span class="text-xs px-2 py-0.5 rounded-full" style="background:${statusBg}; color:${statusColor};">${statusLabel}</span>
